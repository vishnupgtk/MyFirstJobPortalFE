# =============================================================================
# HIRING SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and update the values for your environment.
# This file serves as documentation for all available environment variables.
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://localhost:7233/api
VITE_API_TIMEOUT=10000

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
VITE_APP_ENV=development
VITE_APP_NAME=Hiring System
VITE_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_API_LOGGING=true

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
VITE_TOKEN_STORAGE_KEY=hiring_system_token
VITE_SESSION_TIMEOUT=60

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Update VITE_API_BASE_URL with your backend URL
# 3. For production, set VITE_APP_ENV=production and disable dev tools
# 4. Change VITE_TOKEN_STORAGE_KEY for production security
# =============================================================================